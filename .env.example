# ── Advanced RAG Pipeline – Environment Configuration ─────────────────────────
# Copy this to .env and fill in your values.
# All settings have defaults in config.py, so .env is optional.

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=ai_research

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Choose any model you have pulled with `ollama pull <model>`
# Recommended: llama3.2:3b (fast), llama3.1:8b (smart), mistral:7b
OLLAMA_MODEL=llama3.2:3b

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5


# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=6
SCORE_THRESH=0.30

# ── Ollama Storage Volume ─────────────────────────────────────────────────────
# Use 'ollama_storage' for named volume (default in cloud/GCP),
# or specify host path for bind mount (e.g. C:\Users\rajee\.ollama for local Windows)
OLLAMA_VOLUME=ollama_storage

